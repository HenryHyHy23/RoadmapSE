<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head', { title: 'Góc Học Tập' }) %>
</head>

<body class="d-flex flex-column h-100">
    <%- include('partials/floating-shapes') %>

        <main class="flex-shrink-0">
            <%- include('partials/navbar', { page: 'learn' }) %>

                <div class="px-5 my-5">
                    <div class="text-center mb-5">
                        <h1 class="display-5 fw-bolder mb-0">
                            <span class="text-gradient d-inline">RoadMap</span>
                        </h1>
                    </div>

                    <div class="row g-5">
                        <!-- Sidebar: danh sách môn học -->
                        <div class="col-lg-4">
                            <div class="dropdown mb-4">
                                <button class="btn bg-gradient-primary-to-secondary dropdown-toggle w-100 text-start"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                    style="color: white; font-size: 1.25rem;">
                                    Semester 3
                                </button>
                            </div>
                            <div class="timeline list-group" id="v-pills-tab" role="tablist"
                                aria-orientation="vertical">
                                <div class="text-center py-5">
                                    <div class="spinner-border text-primary"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Main content: nội dung bài học -->
                        <div class="col-lg-8">
                            <div class="d-flex justify-content-end mb-4">
                                <a id="btn-download-dynamic" class="btn btn-primary px-4 py-3 shadow-sm" href="#"
                                    target="_blank">
                                    <div class="d-inline-block bi bi-download me-2"></div>
                                    Tải tài liệu
                                </a>
                            </div>
                            <div class="card shadow border-0 sticky-top" style="top: 100px; min-height: 300px;">
                                <div class="card-body p-5">
                                    <div class="tab-content" id="v-pills-tabContent">
                                        <div class="text-center py-5">Đang tải dữ liệu...</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        </main>

        <%- include('partials/footer') %>

            <!-- Offcanvas chi tiết bài học -->
            <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="lessonOffcanvas">
                <div class="offcanvas-header bg-headcanvas text-white">
                    <h4 class="offcanvas-title d-flex align-items-center">
                        <i class="bi bi-book-half me-2"></i>
                        <span id="offcanvasTitle"></span>
                    </h4>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"
                        aria-label="Close"></button>
                </div>
                <div class="offcanvas-body bg-light" id="offcanvasContent">
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" defer></script>
            <script src="/js/scripts.js" defer></script>
            <script>
                window.MathJax = {
                    tex: {
                        inlineMath: [['\\(', '\\)']],
                        displayMath: [['\\[', '\\]']]
                    }
                };
            </script>
            <script id="MathJax-script" async
                src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
</body>

</html>