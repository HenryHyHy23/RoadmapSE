<!DOCTYPE html>
<html lang="vi">
  <head>
    <%- include('partials/head', { title: 'Luyện Công' }) %>
  </head>

  <body class="d-flex flex-column h-100">
    <%- include('partials/floating-shapes') %>

    <main class="flex-shrink-0">
      <%- include('partials/navbar', { page: 'challenge' }) %>
      <div class="container my-5">
        <div
          class="search-wrapper"
          style="
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            padding: 24px;
          "
        >
          <div class="row align-items-center mb-2">
            <div class="col-md-5 mb-3 mb-md-0">
              <h2 class="fw-bold mb-1" style="color: #1e293b">
                Global Search
              </h2>
              <p class="text-muted mb-0" style="font-size: 0.9rem">
                Tìm kiếm theo từng bước: Môn học ➔ Chủ đề ➔ Nội dung
              </p>
            </div>

            <div class="col-md-7">
              <div
                class="search-box d-flex align-items-center p-2"
                style="
                  border: 2px solid #cbd5e1;
                  border-radius: 50px;
                  background: #f8fafc;
                  transition: all 0.3s;
                "
              >
                <i class="bi bi-search text-muted ms-3 me-3"></i>

                <div
                  id="searchBadges"
                  class="d-flex align-items-center gap-2 me-2"
                ></div>

                <input
                  type="text"
                  id="globalSearchInput"
                  class="form-control border-0 bg-transparent shadow-none p-0"
                  placeholder="Gõ từ khóa hoặc chọn gợi ý bên dưới"
                  style="outline: none"
                />
              </div>
            </div>
          </div>

          <div class="row mb-4">
            <div class="col-md-5"></div>
            <div class="col-md-7">
              <div
                id="searchSuggestions"
                class="d-flex flex-wrap gap-2 align-items-center"
              ></div>
            </div>
          </div>

          <div id="defaultState" class="text-center py-5">
            <i
              class="bi bi-journal-code text-light"
              style="font-size: 4rem"
            ></i>
            <h5 class="mt-3 text-muted">Bắt đầu bằng cách chọn một mã môn học</h5>
          </div>

          <div id="globalSearchResults" class="row" style="display: none"></div>
        </div>
      </div>

      <div class="px-5 my-5">
        <div class="text-center mb-5">
          <h1 class="display-5 fw-bolder mb-0">
            <span class="text-gradient d-inline">Quiz</span>
          </h1>
          <p class="lead fw-normal text-muted mb-0">
            Ôn lại những gì đã học!!!
          </p>
        </div>

        <div id="challenge-tab" class="mb-5">
          <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
          </div>
        </div>

        <div class="tab-content" id="challenge-tabContent"></div>
      </div>
    </main>

    <%- include('partials/footer') %>

    <div id="quiz-modal" class="modal-backdrop-quiz">
      <div class="quiz-box">
        <div class="quiz-header">
          <h3 id="subject-title">Quiz</h3>
          <span style="cursor: pointer; font-size: 24px" onclick="closeQuiz()"
            >&times;</span
          >
        </div>
        <div class="quiz-body" id="quiz-content"></div>
        <div class="quiz-footer">
          <span id="question-status" class="fw-bold text-muted">Câu 0/0</span>
          <button id="next-btn" onclick="nextQuestion()" disabled>
            Tiếp theo
          </button>
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
      defer
    ></script>
    <script src="/js/scripts.js" defer></script>
    <script src="/js/quiz-timer.js" defer></script>
    <script src="/js/global-search.js"></script>
  </body>
</html>
